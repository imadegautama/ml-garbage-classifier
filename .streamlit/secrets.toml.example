# Template secrets untuk Streamlit — SALIN ke `.streamlit/secrets.toml` lalu isi key asli.
# File `.streamlit/secrets.toml` SUDAH di-gitignore (aman, tidak ikut ter-commit).
#
# Cara pakai (lokal):
#   1. cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Ganti nilai di bawah dengan API key OpenRouter Anda (buat di https://openrouter.ai/keys).
#
# Di Streamlit Community Cloud: tempel isi ini lewat menu "Settings → Secrets".

OPENROUTER_API_KEY = "sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
